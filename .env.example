# Copia questo file in `.env` (gitignored) e riempi con le tue credenziali Dreamehome.
# Il `.env` viene caricato manualmente prima di runnare i tools/:
#
#   set -a; source .env; set +a
#   .venv/bin/python tools/scan_properties.py --label list
#
# NON committare mai `.env` — `.gitignore` lo esclude di default.

DREAME_USERNAME=you@example.com
DREAME_PASSWORD=hunter2

# Regione Dreame cloud (eu, cn, us, sg, ru). Default eu.
# DREAME_REGION=eu
