# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example

# Credenziali e segreti
secrets*
*.local.json
*.secret.json
credentials*.json

# Network capture / debugging dumps (possono contenere token, cookies, payload)
*.proxymansessionv2
*.proxymansession
*.har
*.pcap
*.pcapng

# Snapshot di discovery (possono contenere DID/MAC/dati device)
dev/research/snapshots/*.json
dev/research/diffs/*.txt
dev/research/diffs/*.json
!dev/research/snapshots/.gitkeep
!dev/research/diffs/.gitkeep
!dev/research/snapshots/example.json
!dev/research/diffs/example.txt

# Repo di riferimento locali (clonati per consultazione offline)
tmp/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Home Assistant test sandbox (sandbox/config/ runtime state)
.HA_VERSION
home-assistant.log*
home-assistant_v2.db*
.storage/
sandbox/config/*
!sandbox/config/configuration.yaml
